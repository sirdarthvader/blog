---
interface Props {
  title: string;
  description: string;
  slug: string;
  tags: string[];
  url?: string;
  github?: string;
}

const { title, description, slug, url, github } = Astro.props;
---

<article style="padding: 0.75rem 0;">
  <a href={`/projects/${slug}`} style="text-decoration: none;">
    <h2 style="font-weight: 500; font-size: 1rem; margin-bottom: 0.25rem;" class="project-title">
      {title}
    </h2>
    <p style="font-size: 0.9375rem; color: rgb(115 115 115); line-height: 1.625; margin-bottom: 0.5rem;">{description}</p>
  </a>
  <div style="display: flex; gap: 1rem;">
    {github && (
      <a href={github} target="_blank" rel="noopener noreferrer" style="font-family: ui-monospace, monospace; font-size: 0.75rem; color: rgb(115 115 115);">
        GitHub ↗
      </a>
    )}
    {url && (
      <a href={url} target="_blank" rel="noopener noreferrer" style="font-family: ui-monospace, monospace; font-size: 0.75rem; color: rgb(115 115 115);">
        Live ↗
      </a>
    )}
  </div>
</article>

<style>
  .project-title {
    color: rgb(23 23 23);
  }

  @media (prefers-color-scheme: dark) {
    .project-title {
      color: rgb(245 245 245);
    }
  }
</style>
