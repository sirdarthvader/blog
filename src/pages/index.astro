---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Home" description="Software engineer exploring systems, mathematics, physics, and the ideas that connect them.">
  <h1 class="name">Ashish Singh</h1>

  <div class="content">
    <p>
    Software engineer, One who left VS Code for NeoVim and never looked back.
    I work on platform tooling in TypeScript monorepos at <a href="https://www.cvent.com" target="_blank">Cvent</a>, and on the side I'm building a chess engine becuase why not.
    </p>

    <p>
      I <a href="/blog">write here</a> when something is worth writing down.
    </p>

    <p class="footer-links">
      Find me on <a href="https://github.com/sirdarthvader" target="_blank" rel="noopener noreferrer">GitHub</a> or,
      <a href="https://linkedin.com/in/ashish-nandan-singh" target="_blank" rel="noopener noreferrer">LinkedIn</a>
      
    </p>
  </div>
</BaseLayout>

<style>
  .name {
    font-size: 1.25rem;
    font-weight: 500;
    margin-bottom: 1.5rem;
    line-height: 1.625;
    color: var(--text-heading);
  }

  .content {
    line-height: 1.75;
  }

  .content p {
    margin-bottom: 1.25rem;
    color: var(--text-copy);
  }

  .footer-links {
    margin-top: 2rem;
    color: var(--text-nav) !important;
    font-size: 0.9375rem;
  }
</style>
