---
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import TagList from '../components/TagList.astro';
import GiscusComments from '../components/GiscusComments.astro';

interface Props {
  title: string;
  description: string;
  publishedAt: Date;
  updatedAt?: Date;
  tags: string[];
}

const { title, description, publishedAt, updatedAt, tags } = Astro.props;
---

<BaseLayout title={title} description={description} article publishedAt={publishedAt}>
  <article>
    <header style="margin-bottom: 2.5rem;">
      <div style="font-family: ui-monospace, monospace; font-size: 0.875rem; color: var(--text-nav); margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem;">
        <FormattedDate date={publishedAt} />
        {updatedAt && (
          <>
            <span>·</span>
            <span>Updated <FormattedDate date={updatedAt} /></span>
          </>
        )}
      </div>
      <h1 style="font-size: 1.5rem; font-weight: 500; letter-spacing: -0.015em; margin-bottom: 1rem; color: var(--text-heading);">
        {title}
      </h1>
      <p style="color: var(--text-nav); font-size: 1.0625rem; line-height: 1.75;">{description}</p>
      {tags.length > 0 && (
        <div style="margin-top: 1rem;">
          <TagList tags={tags} />
        </div>
      )}
    </header>

    <div class="prose">
      <slot />
    </div>

    <footer style="margin-top: 4rem; padding-top: 2rem; border-top: 1px solid var(--border);">
      <GiscusComments />
    </footer>
  </article>
</BaseLayout>
