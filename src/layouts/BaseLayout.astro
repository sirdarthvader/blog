---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  article?: boolean;
  publishedAt?: Date;
}

const {
  title,
  description = 'Developer, writer, builder.',
  ogImage,
  article = false,
  publishedAt,
} = Astro.props;

const siteUrl = Astro.site ?? 'https://yoursite.com';
const canonicalURL = new URL(Astro.url.pathname, siteUrl);
const ogImageURL = ogImage ? new URL(ogImage, siteUrl) : new URL('/og-default.png', siteUrl);

const fullTitle = title === 'Home' ? 'Ashish N Singh' : `${title} — Ashish`;
const isHome = Astro.url.pathname === '/';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content={article ? 'article' : 'website'} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    {article && publishedAt && (
      <meta property="article:published_time" content={publishedAt.toISOString()} />
    )}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- RSS -->
    <link rel="alternate" type="application/rss+xml" title="Your Name — Blog" href="/rss.xml" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <main style="width: 100%; max-width: 36rem; margin-left: auto; margin-right: auto; padding: 3rem 1.5rem 5rem;">
      {!isHome && (
        <nav class="mb-8">
          <a href="/" style="text-decoration: none; color: var(--text-nav); font-size: 0.875rem;">← home</a>
        </nav>
      )}
      <slot />
    </main>
  </body>
</html>
